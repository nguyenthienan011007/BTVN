    rule22a, rule22b, rule23a, rule23b, rule24a, rule24b,
    rule25a, rule25b, rule26a, rule26b, rule27a, rule27b,
]

washing_ctrl=ctrl.ControlSystem(rules)
washing_simulation=ctrl.ControlSystemSimulation(washing_ctrl)


washing_simulation.input['khoiluong']= 7.5  # kg
washing_simulation.input['doban']= 60   # %
washing_simulation.input['loaivai']= 80   # (80 ~ Dày)
washing_simulation.compute()

print(f"Thời gian giặt:{washing_simulation.output['thoigiangiat']:.2f} phút")
print(f"Mực nước:{washing_simulation.output['mucnuoc']:.2f} lít")


thoigiangiat.view(sim=washing_simulation)
mucnuoc.view(sim=washing_simulation)
