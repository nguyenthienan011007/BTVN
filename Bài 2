rule20b = ctrl.Rule(khoiluong['Nặng'] & doban['Thấp'] & loaivai['Trung bình'],mucnuoc['Trung bình'])
rule21a = ctrl.Rule(khoiluong['Nặng'] & doban['Thấp'] & loaivai['Dày'],thoigiangiat['Dài'])
