rule10a = ctrl.Rule(khoiluong['Trung bình'] & doban['Thấp'] & loaivai['Mềm'],thoigiangiat['Trung bình'])
rule10b = ctrl.Rule(khoiluong['Trung bình'] & doban['Thấp'] & loaivai['Mềm'],mucnuoc['Trung bình'])
