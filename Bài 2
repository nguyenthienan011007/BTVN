    rule4a,  rule4b,  rule5a,  rule5b,  rule6a,  rule6b,
    rule7a,  rule7b,  rule8a,  rule8b,  rule9a,  rule9b,
    rule10a, rule10b, rule11a, rule11b, rule12a, rule12b,
