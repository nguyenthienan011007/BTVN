
import numpy as np
import skfuzzy as fuzz
from skfuzzy import control as ctrl
khoiluong = ctrl.Antecedent(np.arange(0, 11, 1), 'khoiluong')
doban= ctrl.Antecedent(np.arange(0, 101, 1), 'doban')
loaivai= ctrl.Antecedent(np.arange(0, 101, 1), 'loaivai')
thoigiangiat = ctrl.Consequent(np.arange(0, 61, 1), 'thoigiangiat')
mucnuoc= ctrl.Consequent(np.arange(0, 101, 1), 'mucnuoc')
khoiluong['Nhẹ']= fuzz.trimf(khoiluong.universe, [0, 0, 4])
khoiluong['Trung bình'] = fuzz.trimf(khoiluong.universe, [3, 5, 7])
khoiluong['Nặng']= fuzz.trimf(khoiluong.universe, [6, 10, 10])
doban['Thấp']= fuzz.trimf(doban.universe, [0, 0, 40])
doban['Trung bình'] = fuzz.trimf(doban.universe, [30, 50, 70])
doban['Cao'] = fuzz.trimf(doban.universe, [60, 100, 100])
loaivai['Mềm']= fuzz.trimf(loaivai.universe, [0, 0, 40])
loaivai['Trung bình'] = fuzz.trimf(loaivai.universe, [30, 50, 70])
loaivai['Dày']= fuzz.trimf(loaivai.universe, [60, 100, 100])
thoigiangiat['Ngắn']= fuzz.trimf(thoigiangiat.universe, [0, 0, 25])
thoigiangiat['Trung bình'] = fuzz.trimf(thoigiangiat.universe, [20, 35, 50])
thoigiangiat['Dài']= fuzz.trimf(thoigiangiat.universe, [45, 60, 60])
mucnuoc['Thấp']= fuzz.trimf(mucnuoc.universe, [0, 0, 40])
mucnuoc['Trung bình'] = fuzz.trimf(mucnuoc.universe, [30, 50, 70])
mucnuoc['Cao']= fuzz.trimf(mucnuoc.universe, [60, 100, 100])

rule1a  = ctrl.Rule(khoiluong['Nhẹ'] & doban['Thấp'] & loaivai['Mềm'],thoigiangiat['Ngắn'])
