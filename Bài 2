rule14b = ctrl.Rule(khoiluong['Trung bình'] & doban['Trung bình'] & loaivai['Trung bình'],mucnuoc['Trung bình'])
rule15a = ctrl.Rule(khoiluong['Trung bình'] & doban['Trung bình'] & loaivai['Dày'],thoigiangiat['Dài'])
