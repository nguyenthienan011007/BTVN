# 2. KHOẢNG CÁCH BẢN ĐỒ THẬT (OpenStreetMap)
# ══════════════════════════════════════════════════════════
@st.cache_data(ttl=86400)
def geocode(address: str):
    """Chuyển địa chỉ → (lat, lon) dùng Nominatim — miễn phí."""
    try:
        resp = requests.get(
            "https://nominatim.openstreetmap.org/search",
            params={"q": address + ", Việt Nam", "format": "json",
                    "limit": 1, "accept-language": "vi"},
            headers={"User-Agent": "GrabBike-App/2.0"},
            timeout=8
        )
        data = resp.json()
        if data:
            return float(data[0]["lat"]), float(data[0]["lon"])
    except Exception:
        pass
    return None, None


@st.cache_data(ttl=86400)
def get_road_distance(pickup: str, destination: str) -> tuple:
    """
    Khoảng cách đường bộ thật qua OSRM (OpenStreetMap Routing).
    Trả về: (km, phút, nguồn_chuỗi)
    """
    lat1, lon1 = geocode(pickup)
    lat2, lon2 = geocode(destination)

    # OSRM routing
    if lat1 and lat2:
        try:
            url = (f"https://router.project-osrm.org/route/v1/driving/"
                   f"{lon1},{lat1};{lon2},{lat2}?overview=false")
            resp = requests.get(url,
                                headers={"User-Agent": "GrabBike-App/2.0"},
                                timeout=10)
            data = resp.json()
            if data.get("code") == "Ok" and data.get("routes"):
                route   = data["routes"][0]
                dist_km = round(route["distance"] / 1000, 1)
                eta_min = max(1, round(route["duration"] / 60))
                return dist_km, eta_min, "bản đồ thật 🗺️"
        except Exception:
            pass

        # Fallback Haversine × 1.35
        R    = 6371
        dlat = math.radians(lat2 - lat1)
        dlon = math.radians(lon2 - lon1)
        a    = (math.sin(dlat/2)**2 +
                math.cos(math.radians(lat1)) *
                math.cos(math.radians(lat2)) *
                math.sin(dlon/2)**2)
        bird = R * 2 * math.atan2(math.sqrt(a), math.sqrt(1 - a))
        dist = round(bird * 1.35, 1)
        eta  = max(1, int(dist / 30 * 60))
        return dist, eta, "ước tính từ toạ độ 📍"

    # Không geocode được
    dist = round(random.uniform(3, 18), 1)
    return dist, max(1, int(dist / 30 * 60)), "ước tính ⚠️"


