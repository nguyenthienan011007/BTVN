def page_history():
    user  = st.session_state.user
    trips = db_get_trips(user["id"])

    st.markdown("""
    <h1 style="color:#00B14F;margin:0 0 18px 0;font-size:26px">📋 Lịch sử chuyến đi</h1>
    """, unsafe_allow_html=True)

    total       = len(trips)
    total_spend = sum(t["ai_price"] for t in trips)
    avg_rating  = (sum(t["driver_rating"] for t in trips) / total) if total else 0
    car_count   = sum(1 for t in trips if "Car" in t.get("vehicle",""))

    c1, c2, c3, c4 = st.columns(4)
    with c1: st.metric("🏍️ Tổng chuyến", total)
    with c2: st.metric("💰 Tổng chi tiêu", fmt(total_spend))
    with c3: st.metric("⭐ Đánh giá TB", f"{avg_rating:.1f}" if total else "---")
    with c4: st.metric("🚗 GrabCar", car_count)

    st.markdown("<br>", unsafe_allow_html=True)
    c_f, c_r = st.columns([3, 1])
    with c_f:
        flt = st.selectbox("Lọc loại xe", ["Tất cả"] + list(VEHICLES.keys()),
                            key="flt")
    with c_r:
        st.markdown("<br>", unsafe_allow_html=True)
        if st.button("🔄 Làm mới"):
            st.session_state["confirm_refresh"] = True

    if st.session_state.get("confirm_refresh"):
        st.warning("⚠️ Bạn có chắc muốn làm mới danh sách không?")
        col_yes, col_no = st.columns(2)
        with col_yes:
            if st.button("✅ Xác nhận", use_container_width=True, key="yes_refresh"):
                st.session_state["confirm_refresh"] = False
                st.rerun()
        with col_no:
            if st.button("❌ Huỷ", use_container_width=True, key="no_refresh"):
                st.session_state["confirm_refresh"] = False
                st.rerun()

    if flt != "Tất cả":
        trips = [t for t in trips if t.get("vehicle","") == flt]

    if not trips:
        st.markdown("""
        <div style="text-align:center;padding:50px 20px;color:#adb5bd">
            <div style="font-size:56px">🛵</div>
            <p style="font-size:15px;font-weight:600;margin-top:10px">
