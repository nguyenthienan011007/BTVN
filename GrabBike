@st.cache_resource
def get_db():
    conn = sqlite3.connect("grabbike.db", check_same_thread=False)
    conn.row_factory = sqlite3.Row
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password TEXT NOT NULL,
            fullname TEXT NOT NULL,
            phone TEXT DEFAULT '',
            role TEXT DEFAULT 'customer',
            created TEXT DEFAULT (datetime('now','localtime'))
        );
        CREATE TABLE IF NOT EXISTS trips (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            pickup TEXT NOT NULL,
            destination TEXT NOT NULL,
            distance REAL NOT NULL,
            base_price REAL NOT NULL,
            ai_price REAL NOT NULL,
            vehicle TEXT DEFAULT 'GrabBike',
            weather TEXT,
            demand TEXT,
            is_peak INTEGER DEFAULT 0,
            fuel_price REAL DEFAULT 22000,
            driver_name TEXT,
            driver_rating REAL DEFAULT 4.8,
            dist_source TEXT DEFAULT '',
            created TEXT DEFAULT (datetime('now','localtime'))
        );
    """)
    conn.commit()
    cur = conn.cursor()
    cur.execute("SELECT COUNT(*) FROM users")
    if cur.fetchone()[0] == 0:
        h = lambda p: hashlib.sha256(p.encode()).hexdigest()
        cur.executemany(
            "INSERT INTO users (username,password,fullname,phone,role) VALUES (?,?,?,?,?)",
            [("demo", h("123456"), "Nguyễn Văn Demo", "0901234567", "customer")]
        )
        conn.commit()
    return conn

def hash_pw(pw): return hashlib.sha256(pw.encode()).hexdigest()

def db_login(u, p):
    row = get_db().execute(
        "SELECT * FROM users WHERE username=? AND password=?", (u, hash_pw(p))
    ).fetchone()
    return dict(row) if row else None

def db_register(u, p, n, ph, r):
    try:
        get_db().execute(
            "INSERT INTO users (username,password,fullname,phone,role) VALUES (?,?,?,?,?)",
            (u, hash_pw(p), n, ph, r)
        )
        get_db().commit()
        return True, "Đăng ký thành công!"
    except sqlite3.IntegrityError:
        return False, "Tên đăng nhập đã tồn tại!"

def db_save_trip(uid, pickup, dest, dist, base, ai, vehicle,
                  weather, demand, is_peak, fuel, driver, rating, src):
    get_db().execute("""
        INSERT INTO trips
          (user_id,pickup,destination,distance,base_price,ai_price,vehicle,
           weather,demand,is_peak,fuel_price,driver_name,driver_rating,dist_source)
        VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)
    """, (uid, pickup, dest, dist, base, ai, vehicle,
          weather, demand, int(is_peak), fuel, driver, rating, src))
    get_db().commit()

def db_get_trips(uid):
    rows = get_db().execute(
        "SELECT * FROM trips WHERE user_id=? ORDER BY id DESC", (uid,)
    ).fetchall()
    return [dict(r) for r in rows]


