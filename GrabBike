        peak_str = "⏰ Cao điểm" if t["is_peak"] else "🕐 Thường"

        st.markdown(f"""
        <div class="trip-card">
            <div style="display:flex;align-items:center;gap:13px">
                <div style="width:46px;height:46px;border-radius:11px;
                            background:{cfg['color']}18;display:flex;align-items:center;
                            justify-content:center;font-size:20px;flex-shrink:0">
                    {cfg['icon']}
                </div>
                <div style="flex:1">
                    <div style="font-weight:800;font-size:14px">
                        {t['pickup']} → {t['destination']}
                    </div>
                    <div style="font-size:12px;color:#6c757d;margin-top:3px">
                        📏 {t['distance']:.1f} km {('· '+src) if src else ''}
                        &nbsp;·&nbsp; 🧑‍💼 {t['driver_name']}
                        &nbsp;·&nbsp; ⭐ {t['driver_rating']:.1f}
                        &nbsp;·&nbsp; {peak_str}
                    </div>
                    <div style="font-size:11px;color:#adb5bd;margin-top:2px">
                        🕐 {date_str}
