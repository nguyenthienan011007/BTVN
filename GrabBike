        ],
    },
}

WEATHER_MAP = {"Nắng":1.0,"Mây":1.1,"Mưa nhỏ":1.3,"Mưa to":1.5,"Bão":2.0}
DEMAND_MAP  = {"Thấp":0.8,"Bình thường":1.0,"Cao":1.3,"Rất cao":1.6}


@st.cache_resource
def get_ai_models():
    """Train Linear Regression cho từng loại xe."""
    if not HAS_SKLEARN:
        return {}
    models = {}
    for vname, cfg in VEHICLES.items():
        rng  = np.random.default_rng(42)
        n    = 2000
        dist    = rng.uniform(1, 30, n)
        demand  = rng.uniform(0.8, 1.6, n)
        weather = rng.uniform(1.0, 2.0, n)
        fuel    = rng.uniform(20000, 27000, n)
        y = np.clip(
            cfg["rate"] * dist * demand * weather
            + (fuel - 22000) / 1000 * 600 * cfg["mult"]
            + cfg["open"]
            + rng.normal(0, 2000, n),
            15000, None
        )
        X  = np.column_stack([dist, demand, weather, fuel])
        sc = StandardScaler()
        md = LinearRegression().fit(sc.fit_transform(X), y)
        models[vname] = {"model": md, "scaler": sc}
    return models


def calc_price(dist, demand, weather, fuel, is_peak, vname) -> tuple:
    """Trả về (giá_thường, giá_AI)."""
    cfg  = VEHICLES[vname]
    dv   = DEMAND_MAP.get(demand, 1.0)
    wv   = WEATHER_MAP.get(weather, 1.0)
    peak = 1.25 if is_peak else 1.0

    base = (cfg["open"] + cfg["rate"] * dist) * peak
    base = max(round(base / 1000) * 1000, 15_000)

    models = get_ai_models()
    if HAS_SKLEARN and vname in models:
        X  = np.array([[dist, dv, wv, fuel]])
        Xs = models[vname]["scaler"].transform(X)
        p  = float(models[vname]["model"].predict(Xs)[0])
        ai = max(round(p * peak / 1000) * 1000, 15_000)
    else:
        fuel_f = (fuel - 22000) / 1000 * 600 * cfg["mult"]
        p  = cfg["rate"] * dist * dv * wv + fuel_f + cfg["open"]
        ai = max(round(p * peak / 1000) * 1000, 15_000)

    return base, ai


def fmt(v: float) -> str:
    return f"{int(v):,}đ".replace(",", ".")


